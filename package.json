{
  "name": "desin-ai-tool",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "dev": "npm --workspace examples/vite-react run dev",
    "build": "npm run build --workspaces --if-present",
    "check": "npm run typecheck --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "pack:packages": "npm pack --workspace @design-bypupila/inspector --dry-run",
    "release:dry-run": "npm run clean && npm run build && npm run check && npm run pack:packages",
    "release:publish": "npm run clean && npm run build && npm run check && npm publish --workspace @design-bypupila/inspector --access public"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.3",
    "playwright": "^1.61.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vite": "^8.1.4"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
